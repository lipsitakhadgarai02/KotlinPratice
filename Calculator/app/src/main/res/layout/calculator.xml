<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#F5F5F5">

    <!-- History display -->
    <TextView
        android:id="@+id/history"
        android:layout_width="match_parent"
        android:layout_height="106dp"
        android:gravity="end|center_vertical"
        android:text=""
        android:textColor="#888888"
        android:textSize="16sp" />

    <!-- Main display -->
    <TextView
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="146dp"
        android:background="#FFFFFF"
        android:gravity="end|center_vertical"
        android:padding="12dp"
        android:text="0"
        android:textColor="#000000"
        android:textSize="32sp" />

    <!-- Keypad -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5"
        android:layout_marginTop="16dp"
        android:alignmentMode="alignMargins"
        android:useDefaultMargins="true">

        <!-- Row 1 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnC"
            android:text="C"
            style="@style/CalcButtonPink" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBrackets"
            android:text="( )"
            style="@style/CalcButton" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPercent"
            android:text="%"
            style="@style/CalcButton" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDiv"
            android:text="÷"
            style="@style/CalcButton" />

        <!-- Row 2 -->
        <com.google.android.material.button.MaterialButton android:id="@+id/btn7" android:text="7" style="@style/CalcButton" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn8" android:text="8" style="@style/CalcButton" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn9" android:text="9" style="@style/CalcButton" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnMul" android:text="×" style="@style/CalcButton" />

        <!-- Row 3 -->
        <com.google.android.material.button.MaterialButton android:id="@+id/btn4" android:text="4" style="@style/CalcButton" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn5" android:text="5" style="@style/CalcButton" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn6" android:text="6" style="@style/CalcButton" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnSub" android:text="−" style="@style/CalcButton" />

        <!-- Row 4 -->
        <com.google.android.material.button.MaterialButton android:id="@+id/btn1" android:text="1" style="@style/CalcButton" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn2" android:text="2" style="@style/CalcButton" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn3" android:text="3" style="@style/CalcButton" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnAdd" android:text="+" style="@style/CalcButton" />

        <!-- Row 5 -->
        <com.google.android.material.button.MaterialButton android:id="@+id/btnPlusMinus" android:text="+/-" style="@style/CalcButton" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn0" android:text="0" style="@style/CalcButton" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnDot" android:text="." style="@style/CalcButton" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEqual"
            android:text="="
            style="@style/CalcButtonPrimary" />
    </GridLayout>
</LinearLayout>
